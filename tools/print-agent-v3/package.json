{
  "name": "zoopi-print-agent",
  "version": "3.1.0",
  "description": "Agente de Impressão Bitmap para Zoopi - Renderiza HTML para ESC/POS GS v 0",
  "main": "main-electron.js",
  "scripts": {
    "start": "electron .",
    "standalone": "node agent-standalone.js",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "electron-store": "^8.1.0",
    "express": "^4.18.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.zoopi.printagent",
    "productName": "Zoopi Print Agent",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!*.md",
      "!dist/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    }
  }
}
